# Supabase project settings (Project dashboard → Connect)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Server-only secrets. Never prefix these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ADMIN_SECRET=replace_with_a_long_random_value

# Public X direct-message URL used by Contact and Report links.
NEXT_PUBLIC_X_MODERATOR_DM_URL=https://x.com/messages/compose?recipient_id=your_numeric_x_user_id
